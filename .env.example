# ─── DATABASE ───────────────────────────────────────────
# Local/dev default. Use a managed Postgres URL in production when ready.
DATABASE_URL=sqlite:///antigravity.db

# ─── API KEYS ────────────────────────────────────────────
UNUSUAL_WHALES_TOKEN=replace_me
UW_CLIENT_API_ID=100001
UW_BASE_URL=https://api.unusualwhales.com/api

# ─── DISCORD ─────────────────────────────────────────────
DISCORD_BOT_TOKEN=replace_me
DISCORD_GUILD_ID=replace_me

# Canal IDs por tier
DISCORD_FREE_CHANNEL=replace_me
DISCORD_TIER1_CHANNEL=replace_me
DISCORD_TIER2_CHANNEL=replace_me
DISCORD_TIER3_CHANNEL=replace_me
DISCORD_VIP_CHANNEL=replace_me
DISCORD_VICTORIES_CHANNEL=replace_me
DISCORD_MOTIVACION_CHANNEL=replace_me

# ─── APP ─────────────────────────────────────────────────
APP_ENV=production
PORT=8000

# Web process stays dashboard/API only by default.
# Only set true temporarily in local development if you want one process.
RUN_WORKER_IN_WEB=false

# Scanner en el web de Render (sin Discord). Alternativa: segundo servicio con worker.py
ENABLE_LIVERMORE_SCANNER=false

# Relaja solo pisos de premium ~15% (0.85). Tiers 75/85/95 y doctrina no cambian.
LIVERMORE_PREMIUM_RELAX=0.85

# Scanner rate controls for UW Basic limits.
MAX_SCAN_TICKERS=20
SCAN_TICKER_DELAY_SECONDS=4.0

# ─── ANTIGRAVITY LOCAL MVP ───────────────────────────────
AGENT_LOOP_INTERVAL_SECONDS=300
MACRO_INTERVAL_SECONDS=3600
SECTOR_INTERVAL_SECONDS=14400
WHALE_INTERVAL_SECONDS=120
DAILY_LIMIT_BACKOFF_SECONDS=3600
MIN_OPTION_PREMIUM=100000
HIGH_CONVICTION_SCORE=65
STREAMLIT_PORT=8501
